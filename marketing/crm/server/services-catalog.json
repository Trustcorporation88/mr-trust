    {
      "id": "create_ticket",
      "name": "Abrir Novo Ticket",
      "category": "suporte",
      "icon": "ticket",
      "description": "Crie um ticket de suporte para rastrear problemas e solicitações",
      "color": "#8B5CF6",
      "instructions": {
        "what": "Um ticket é um registro de uma solicitação ou problema que precisa ser resolvido, com SLA automático",
        "steps": [
          "Clique em 'Novo Ticket'",
          "Selecione a categoria do problema",
          "Defina a prioridade",
          "Descreva o problema em detalhes",
          "Atribua a um agente ou deixe na fila",
          "Sistema calcula SLA automaticamente"
        ],
        "requiredFields": [
          {
            "field": "Cliente",
            "type": "select",
            "description": "Quem está relatando o problema"
          },
          {
            "field": "Título",
            "type": "text",
            "description": "Resumo do problema (máx 100 caracteres)"
          },
          {
            "field": "Descrição",
            "type": "textarea",
            "description": "Detalhes completos do problema"
          },
          {
            "field": "Categoria",
            "type": "select",
            "options": ["bug", "feature", "billing", "account", "other"],
            "description": "Tipo de problema"
          },
          {
            "field": "Prioridade",
            "type": "select",
            "options": ["low", "medium", "high"],
            "description": "Urgência - afeta SLA (high = 4h, medium = 24h, low = 72h)"
          }
        ],
        "expectedOutput": {
          "success": "Ticket criado com número único",
          "example": {
            "ticketId": "TKT-12345",
            "status": "open",
            "priority": "high",
            "slaHours": 4,
            "slaDeadline": "26/05/2026 18:00"
          }
        }
      }
    },
