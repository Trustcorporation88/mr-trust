{
  "version": 2,
  "outputDirectory": "dist",
  "env": {
    "NODE_ENV": "production",
    "VITE_API_URL": "https://crm-flax-nu-61.vercel.app/api"
  },
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs24.x",
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {"source": "/(?!api).*", "destination": "/index.html"}
  ]
}
