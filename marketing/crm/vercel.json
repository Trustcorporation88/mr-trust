{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs24.x"
    }
  },
  "trailingSlash": false,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/dist/assets/$1"
    },
    {
      "src": "/(.*\\.(js|css|svg|png|jpg|jpeg|gif|webp)$)",
      "dest": "/frontend/dist/$1"
    },
    {
      "src": "/(?!api)(.*)",
      "dest": "/frontend/dist/index.html"
    }
  ]
}
