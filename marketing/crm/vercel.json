{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs24.x"
    }
  },
  "buildCommand": "npm install && cd frontend && npm install && npm run build && cd ..",
  "trailingSlash": false,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(?!api)(.*)",
      "dest": "/frontend/dist/index.html"
    }
  ],
  "outputDirectory": "frontend/dist"
}
