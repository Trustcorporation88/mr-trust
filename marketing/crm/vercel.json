{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs24.x"
    }
  },
  "buildCommand": "npm install",
  "trailingSlash": false,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/index.html"
    }
  ],
  "outputDirectory": "frontend/dist"
}
