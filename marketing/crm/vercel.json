{
  "version": 2,
  "env": {
    "NODE_ENV": "production",
    "VITE_API_URL": "https://crm-flax-nu-61.vercel.app/api"
  },
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs24.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/index.html"
    }
  ]
}
