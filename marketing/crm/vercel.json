{
  "version": 2,
  "projects": [
    {
      "name": "crm",
      "rootDirectory": "frontend"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "VITE_API_URL": "https://crm-flax-nu-61.vercel.app/api"
  },
  "rewrites": [
    {"source": "/api/auth/:path*", "destination": "/api/auth/:path*"},
    {"source": "/api/services/:path*", "destination": "/api/services"},
    {"source": "/(.*)", "destination": "/index.html"}
  ]
}
